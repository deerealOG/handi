{
  "name": "handi",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:fix": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && set NODE_OPTIONS=--dns-result-order=ipv4first && npx expo start",
    "start:offline": "npx expo start --offline",
    "reset-project": "node ./scripts/reset-project.js",
