// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ================================
// User Types
// ================================
enum UserType {
  CLIENT
  ARTISAN
  BUSINESS
  ADMIN
}

enum ProviderSubType {
  INDIVIDUAL
  BUSINESS
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  SUPPORT
  FINANCE
  CONTENT_MANAGER
  DATA_ANALYST
}

enum VerificationLevel {
  BASIC
  VERIFIED
  CERTIFIED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  SUSPENDED
  BANNED
}

// ================================
// User Model
// ================================
model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  phone              String?            @unique
  passwordHash       String?
  firstName          String
  lastName           String
  avatar             String?
  userType           UserType
  providerSubType    ProviderSubType?
  adminRole          AdminRole?
  isVerified         Boolean            @default(false)
  isEmailVerified    Boolean            @default(false)
  isPhoneVerified    Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  verificationLevel  VerificationLevel  @default(BASIC)

  // Location
  city      String?
  state     String?
  address   String?
  latitude  Float?
  longitude Float?

  // Profile fields
  skills              Json    @default("[]")
  bio                 String?
  rating              Float   @default(0)
  totalJobs           Int     @default(0)
  preferredCategories Json    @default("[]")
  isOnline            Boolean @default(false)

  // Security
  twoFactorEnabled    Boolean @default(false)
  twoFactorSecret     String?

  // Identity verification
  nin               String? // National Identification Number (required for individual providers)
  businessRegNumber String? // RC Number or Business Name Registration (for business accounts)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clientBookings      Booking[]            @relation("ClientBookings")
  artisanBookings     Booking[]            @relation("ArtisanBookings")
  wallet              Wallet?
  sentMessages        Message[]            @relation("SentMessages")
  receivedMessages    Message[]            @relation("ReceivedMessages")
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  verificationCodes   VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  certifications      UserCertification[]
  workExperiences     WorkExperience[]
  nextOfKin           NextOfKin?

  @@index([email])
  @@index([phone])
  @@index([userType])
  @@index([city, state])
}

enum VerificationCodePurpose {
  EMAIL_VERIFY
  PHONE_VERIFY
}

model VerificationCode {
  id        String                  @id @default(uuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  purpose   VerificationCodePurpose
  expiresAt DateTime
  createdAt DateTime                @default(now())

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserCertification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String?
  issuer    String?
  year      String?
  fileName  String?
  fileUrl   String?
  status    String? // pending, verified, rejected
  createdAt DateTime @default(now())

  @@index([userId])
}

model WorkExperience {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  company     String
  duration    String
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model NextOfKin {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone        String
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ================================
// Auth - Refresh Tokens
// ================================
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ================================
// Booking/Job Types
// ================================
enum BookingStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PAID
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
}

// ================================
// Booking Model
// ================================
model Booking {
  id String @id @default(uuid())

  // Participants
  clientId           String
  client             User      @relation("ClientBookings", fields: [clientId], references: [id])
  artisanId          String
  artisan            User      @relation("ArtisanBookings", fields: [artisanId], references: [id])
  businessId         String?
  business           Business? @relation(fields: [businessId], references: [id])
  assignedMemberId   String?
  assignedMemberName String?

  // Job details
  categoryId   String
  categoryName String
  serviceType  String
  description  String
  images       Json   @default("[]")

  // Schedule
  scheduledDate     DateTime
  scheduledTime     String
  estimatedDuration Int      @default(60) // minutes

  // Location
  address   String
  city      String
  latitude  Float?
  longitude Float?

  // Pricing
  estimatedPrice Float
  finalPrice     Float?
  platformFee    Float?

  // Status
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)

  // Timestamps
  acceptedAt         DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  review   Review?
  messages Message[]

  @@index([clientId])
  @@index([artisanId])
  @@index([status])
  @@index([scheduledDate])
}

// ================================
// Review Model
// ================================
model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ================================
// Wallet & Transactions
// ================================
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  EARNING
  PLATFORM_FEE
  PAYOUT
  BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  balance        Float    @default(0)
  pendingBalance Float    @default(0)
  currency       String   @default("NGN")
  isLocked       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String            @id @default(uuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id])
  type        TransactionType
  amount      Float
  fee         Float             @default(0)
  status      TransactionStatus @default(PENDING)
  reference   String            @unique
  description String?
  metadata    Json?

  // For payouts
  bankName      String?
  accountNumber String?
  accountName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
  @@index([reference])
  @@index([type])
  @@index([status])
}

// ================================
// Messaging
// ================================
model Message {
  id         String    @id @default(uuid())
  bookingId  String?
  booking    Booking?  @relation(fields: [bookingId], references: [id])
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  imageUrl   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
}

// ================================
// Notifications
// ================================
enum NotificationType {
  JOB_REQUEST
  JOB_ACCEPTED
  JOB_COMPLETED
  PAYMENT_RECEIVED
  MESSAGE
  REVIEW
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

// ================================
// Service Categories
// ================================
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String
  description String?
  subServices Json     @default("[]")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isActive])
}

// ================================
// KYC Verification Documents
// ================================
enum DocumentType {
  ID_CARD
  DRIVERS_LICENSE
  PASSPORT
  UTILITY_BILL
  CERTIFICATE
  BUSINESS_REG
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationDocument {
  id          String         @id @default(uuid())
  userId      String
  type        DocumentType
  fileUrl     String
  status      DocumentStatus @default(PENDING)
  reviewedBy  String?
  reviewNotes String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

// ================================
// Material Costs (Extra charges during job)
// ================================
enum MaterialStatus {
  PENDING
  APPROVED
  REJECTED
}

model MaterialCost {
  id          String         @id @default(uuid())
  bookingId   String
  description String
  amount      Float
  imageUrl    String?
  status      MaterialStatus @default(PENDING)
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([bookingId])
  @@index([status])
}

// ================================
// Artisan Availability & Scheduling
// ================================
model Availability {
  id        String  @id @default(uuid())
  userId    String
  dayOfWeek Int // 0-6 (Sunday-Saturday)
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean @default(true)

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

model BlockedSlot {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
}

// ================================
// Disputes
// ================================
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  REFUND_CLIENT
  PAY_ARTISAN
  SPLIT_50_50
  PARTIAL_REFUND
  NO_ACTION
}

model Dispute {
  id          String             @id @default(uuid())
  bookingId   String             @unique
  filedById   String
  reason      String
  description String
  evidence    Json               @default("[]")
  status      DisputeStatus      @default(OPEN)
  resolution  DisputeResolution?
  resolvedBy  String?
  resolvedAt  DateTime?
  adminNotes  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([filedById])
}

// ================================
// Business / Agency Management
// ================================
enum BusinessVerificationStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum PriceType {
  FIXED
  HOURLY
  QUOTE
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Business {
  id                 String                      @id @default(uuid())
  name               String
  ownerId            String                      @unique
  description        String?
  logo               String?
  coverImage         String?
  address            String?
  city               String?
  phone              String?
  email              String?
  isVerified         Boolean                     @default(false)
  verificationStatus BusinessVerificationStatus? @default(PENDING)
  cacNumber          String?
  tinNumber          String?
  cacDocumentUrl     String?
  tinDocumentUrl     String?
  utilityBillUrl     String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  members  BusinessMember[]
  services BusinessServiceOffering[]
  bookings Booking[]
  projects BusinessProject[]

  @@index([ownerId])
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  role       String   @default("WORKER") // OWNER, MANAGER, WORKER
  joinedAt   DateTime @default(now())
  isActive   Boolean  @default(true)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model BusinessServiceOffering {
  id           String    @id @default(uuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId   String
  categoryName String
  description  String
  basePrice    Float
  priceType    PriceType
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([businessId])
  @@index([categoryId])
}

model BusinessProject {
  id             String          @id @default(uuid())
  businessId     String
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title          String
  description    String
  serviceType    String
  requiredSkills Json            @default("[]")
  budgetMin      Float
  budgetMax      Float
  address        String
  city           String
  state          String
  priority       ProjectPriority @default(MEDIUM)
  artisansNeeded Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([businessId])
  @@index([priority])
}

// ================================
// AI Chat History
// ================================
model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id           String      @id @default(uuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String // "user" or "assistant"
  content      String
  suggestedCat String? // Suggested category from AI
  createdAt    DateTime    @default(now())

  @@index([sessionId])
}

// ================================
// Vendor & Product Marketplace
// ================================
enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Vendor {
  id                 String       @id @default(uuid())
  userId             String       @unique
  businessName       String
  description        String?
  logo               String?
  coverImage         String?
  address            String?
  city               String?
  state              String?
  phone              String?
  email              String?
  website            String?
  status             VendorStatus @default(PENDING)
  isVerified         Boolean      @default(false)
  cacNumber          String?
  taxId              String?
  bankName           String?
  accountNumber      String?
  accountName        String?
  rating             Float        @default(0)
  totalSales         Int          @default(0)
  commissionRate     Float        @default(10)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  products           Product[]
  orders             Order[]
  tradeOrders        TradeOrder[]

  @@index([userId])
  @@index([status])
  @@index([city, state])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id               String        @id @default(uuid())
  vendorId         String
  vendor           Vendor        @relation(fields: [vendorId], references: [id])
  name             String
  slug             String        @unique
  description      String
  shortDescription String?
  categoryId       String?
  categoryName     String?
  brand            String?
  sku              String?       @unique
  price            Float
  compareAtPrice   Float?
  costPrice        Float?
  currency         String        @default("NGN")
  images           Json          @default("[]")
  tags             Json          @default("[]")
  attributes       Json          @default("{}")
  weight           Float?
  dimensions       Json?
  stock            Int           @default(0)
  lowStockThreshold Int          @default(5)
  status           ProductStatus @default(DRAFT)
  isFeatured       Boolean       @default(false)
  isInstallable    Boolean       @default(false)
  installCategoryId String?
  rating           Float         @default(0)
  reviewCount      Int           @default(0)
  totalSold        Int           @default(0)
  tradePriceEnabled Boolean      @default(false)
  tradePrice       Float?
  bulkMinQuantity  Int?
  bulkPrice        Float?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  reviews          ProductReview[]
  orderItems       OrderItem[]
  tradeOrderItems  TradeOrderItem[]

  @@index([vendorId])
  @@index([categoryName])
  @@index([status])
  @@index([isFeatured])
}

model ProductReview {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String
  rating      Int
  title       String?
  comment     String?
  images      Json     @default("[]")
  isVerified  Boolean  @default(false)
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([userId])
}

// ================================
// Orders
// ================================
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  status          OrderStatus @default(PENDING)
  subtotal        Float
  shippingFee     Float       @default(0)
  tax             Float       @default(0)
  discount        Float       @default(0)
  total           Float
  currency        String      @default("NGN")
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingPhone   String?
  shippingMethod  String?
  trackingNumber  String?
  paymentMethod   String?
  paymentReference String?
  paidAt          DateTime?
  pairedBookingId String?
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  returnedAt      DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String
  productImage String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  attributes  Json?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ================================
// Escrow System
// ================================
enum EscrowStatus {
  HELD
  PARTIAL_RELEASE
  RELEASED
  REFUNDED
  DISPUTED
  EXPIRED
}

model Escrow {
  id               String       @id @default(uuid())
  bookingId        String       @unique
  payerId          String
  payeeId          String
  amount           Float
  platformFee      Float        @default(0)
  payeeAmount      Float
  currency         String       @default("NGN")
  status           EscrowStatus @default(HELD)
  paymentReference String?
  paymentMethod    String?
  autoReleaseAt    DateTime?
  releaseDelayHours Int         @default(48)
  releasedAt       DateTime?
  releasedAmount   Float?
  disputeId        String?
  refundAmount     Float?
  refundReason     String?
  refundedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([bookingId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

// ================================
// Refund Requests
// ================================
enum RefundType {
  CANCELLATION_24H_PLUS
  CANCELLATION_WITHIN_24H
  CANCELLATION_AFTER_ARRIVAL
  PRO_NO_SHOW
  WORK_INCOMPLETE
  DEFECTIVE_PRODUCT
  CHANGE_OF_MIND
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  DENIED
}

model RefundRequest {
  id              String       @id @default(uuid())
  bookingId       String?
  orderId         String?
  userId          String
  type            RefundType
  status          RefundStatus @default(REQUESTED)
  originalAmount  Float
  refundAmount    Float
  refundPercentage Float
  creditAmount    Float        @default(0)
  reason          String?
  adminNotes      String?
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([bookingId])
  @@index([orderId])
}

// ================================
// Smart Matching
// ================================
model MatchPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  preferredDistance  Float    @default(25)
  preferredMinRating Float   @default(4.0)
  preferredPriceRange Json?
  preferGender      String?
  preferVerified    Boolean  @default(true)
  preferExperienced Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model MatchResult {
  id           String   @id @default(uuid())
  bookingId    String?
  clientId     String
  professionalId String
  matchScore   Float
  skillScore   Float    @default(0)
  distanceScore Float   @default(0)
  ratingScore  Float    @default(0)
  availabilityScore Float @default(0)
  priceScore   Float    @default(0)
  distanceKm   Float?
  wasSelected  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([clientId])
  @@index([professionalId])
  @@index([matchScore])
}

// ================================
// Emergency Services
// ================================
model EmergencyRequest {
  id            String   @id @default(uuid())
  bookingId     String?  @unique
  clientId      String
  categoryId    String
  categoryName  String
  description   String
  address       String
  city          String
  latitude      Float?
  longitude     Float?
  urgencyLevel  Int      @default(1)
  surgeMultiplier Float  @default(1.0)
  isResolved    Boolean  @default(false)
  respondedBy   String?
  respondedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
  @@index([isResolved])
  @@index([city])
}

model EmergencyProPool {
  id         String   @id @default(uuid())
  userId     String   @unique
  categoryIds Json    @default("[]")
  isAvailable Boolean @default(true)
  maxDistance Float    @default(15)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isAvailable])
}

// ================================
// Maintenance Plans
// ================================
enum PlanInterval {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

model MaintenancePlan {
  id             String       @id @default(uuid())
  name           String
  description    String
  categoryIds    Json         @default("[]")
  interval       PlanInterval
  price          Float
  currency       String       @default("NGN")
  includedVisits Int          @default(1)
  features       Json         @default("[]")
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PlanSubscription {
  id              String             @id @default(uuid())
  userId          String
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  nextBillingDate DateTime
  endDate         DateTime?
  visitsUsed      Int                @default(0)
  visitsRemaining Int                @default(0)
  autoRenew       Boolean            @default(true)
  paymentMethod   String?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  scheduledVisits RecurringBooking[]

  @@index([userId])
  @@index([status])
}

model RecurringBooking {
  id               String           @id @default(uuid())
  subscriptionId   String
  subscription     PlanSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  bookingId        String?
  scheduledDate    DateTime
  categoryName     String
  serviceType      String
  status           String           @default("SCHEDULED")
  completedAt      DateTime?
  createdAt        DateTime         @default(now())

  @@index([subscriptionId])
  @@index([scheduledDate])
}

// ================================
// Home Profile
// ================================
model HomeProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  nickname        String?
  propertyType    String?
  squareFootage   Float?
  yearBuilt       Int?
  bedrooms        Int?
  bathrooms       Int?
  floors          Int?
  address         String?
  city            String?
  state           String?
  latitude        Float?
  longitude       Float?
  appliances      Json     @default("[]")
  systems         Json     @default("[]")
  documents       Json     @default("[]")
  serviceHistory  Json     @default("[]")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ================================
// Quote Management
// ================================
enum QuoteStatus {
  REQUESTED
  RECEIVED
  ACCEPTED
  DECLINED
  EXPIRED
  NEGOTIATING
}

model QuoteRequest {
  id            String   @id @default(uuid())
  clientId      String
  categoryId    String
  categoryName  String
  serviceType   String
  description   String
  images        Json     @default("[]")
  address       String
  city          String
  preferredDate DateTime?
  budget        Json?
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quotes        Quote[]

  @@index([clientId])
  @@index([status])
}

model Quote {
  id              String      @id @default(uuid())
  quoteRequestId  String
  quoteRequest    QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  professionalId  String
  amount          Float
  breakdownItems  Json        @default("[]")
  estimatedDuration Int?
  validUntil      DateTime
  message         String?
  status          QuoteStatus @default(RECEIVED)
  counterOffer    Float?
  negotiationNotes Json       @default("[]")
  acceptedAt      DateTime?
  declinedAt      DateTime?
  bookingId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([quoteRequestId])
  @@index([professionalId])
  @@index([status])
}

// ================================
// Loyalty & Rewards
// ================================
enum PointsAction {
  BOOKING_COMPLETED
  REFERRAL_SIGNUP
  REFERRAL_FIRST_BOOKING
  REVIEW_SUBMITTED
  MILESTONE_REACHED
  PRODUCT_PURCHASE
  POINTS_REDEEMED
  BONUS_AWARDED
  POINTS_EXPIRED
}

model LoyaltyAccount {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalPoints     Int      @default(0)
  availablePoints Int      @default(0)
  lifetimePoints  Int      @default(0)
  tier            String   @default("BRONZE")
  referralCode    String   @unique
  totalReferrals  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    PointsTransaction[]

  @@index([userId])
  @@index([referralCode])
}

model PointsTransaction {
  id          String       @id @default(uuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  action      PointsAction
  points      Int
  description String
  referenceId String?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())

  @@index([accountId])
  @@index([action])
}

// ================================
// Service Guarantee
// ================================
enum GuaranteeClaimStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED_RESERVICE
  APPROVED_REFUND
  DENIED
  COMPLETED
}

model GuaranteeClaim {
  id              String               @id @default(uuid())
  bookingId       String
  clientId        String
  issue           String
  description     String
  evidence        Json                 @default("[]")
  status          GuaranteeClaimStatus @default(SUBMITTED)
  resolution      String?
  reServiceBookingId String?
  refundAmount    Float?
  reviewedBy      String?
  reviewNotes     String?
  resolvedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([bookingId])
  @@index([clientId])
  @@index([status])
}

// ================================
// Trade Purchasing
// ================================
enum TradeOrderStatus {
  PENDING
  APPROVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model TradeAccount {
  id             String   @id @default(uuid())
  userId         String   @unique
  creditLimit    Float    @default(0)
  creditUsed     Float    @default(0)
  creditAvailable Float   @default(0)
  paymentTerms   Int      @default(30)
  isApproved     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders         TradeOrder[]

  @@index([userId])
}

model TradeOrder {
  id              String           @id @default(uuid())
  tradeAccountId  String
  tradeAccount    TradeAccount     @relation(fields: [tradeAccountId], references: [id])
  vendorId        String
  vendor          Vendor           @relation(fields: [vendorId], references: [id])
  orderNumber     String           @unique
  status          TradeOrderStatus @default(PENDING)
  subtotal        Float
  discount        Float            @default(0)
  total           Float
  currency        String           @default("NGN")
  deliveryAddress String
  deliveryCity    String
  deliveryState   String
  deliveryNotes   String?
  bookingId       String?
  isPaidOnCredit  Boolean          @default(false)
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  items           TradeOrderItem[]

  @@index([tradeAccountId])
  @@index([vendorId])
  @@index([status])
}

model TradeOrderItem {
  id          String     @id @default(uuid())
  orderId     String
  order       TradeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

// ================================
// Insurance & Compliance
// ================================
model InsurancePolicy {
  id            String   @id @default(uuid())
  userId        String
  policyNumber  String
  provider      String
  coverageType  String
  coverageAmount Float
  currency      String   @default("NGN")
  startDate     DateTime
  expiryDate    DateTime
  documentUrl   String?
  isVerified    Boolean  @default(false)
  verifiedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([expiryDate])
}

model SLARecord {
  id             String   @id @default(uuid())
  userId         String
  metricType     String
  period         String
  totalEvents    Int      @default(0)
  compliantEvents Int     @default(0)
  complianceRate Float    @default(100)
  violations     Int      @default(0)
  lastViolationAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, metricType, period])
  @@index([userId])
  @@index([complianceRate])
}

// ================================
// Dispute Stage Tracking (Enhanced)
// ================================
enum DisputeStage {
  DIRECT_RESOLUTION
  MEDIATION
  FORMAL_REVIEW
  EXTERNAL_ARBITRATION
}

model DisputeTimeline {
  id            String       @id @default(uuid())
  disputeId     String
  stage         DisputeStage
  startedAt     DateTime     @default(now())
  deadline      DateTime
  completedAt   DateTime?
  assignedTo    String?
  notes         String?
  outcome       String?
  createdAt     DateTime     @default(now())

  @@index([disputeId])
  @@index([stage])
}

// ================================
// Enhanced Reviews (Two-way)
// ================================
model ProReview {
  id              String   @id @default(uuid())
  bookingId       String   @unique
  professionalId  String
  clientId        String
  rating          Int
  comment         String?
  punctuality     Int?
  communication   Int?
  propertyReadiness Int?
  createdAt       DateTime @default(now())

  @@index([professionalId])
  @@index([clientId])
}

model ReviewResponse {
  id        String   @id @default(uuid())
  reviewId  String   @unique
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// ================================
// Message Attachments
// ================================
model MessageAttachment {
  id         String   @id @default(uuid())
  messageId  String
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  createdAt  DateTime @default(now())

  @@index([messageId])
}

// ================================
// Smart Recommendations
// ================================
model UserRecommendation {
  id              String   @id @default(uuid())
  userId          String
  type            String
  referenceId     String
  score           Float
  reason          String
  isViewed        Boolean  @default(false)
  isActedOn       Boolean  @default(false)
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  @@index([userId])
  @@index([type])
  @@index([score])
}
